{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "jsx": "preserve",
    "jsxImportSource": "@nativescript-dom/solidjs-types",
    "rootDirs": [".", "../.."],
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@/*": ["src/*"],
      "@nativescript/*": ["../../packages/*"],
      "@nativescript/tanstack-router": ["../../packages/tanstack-router/index.d.ts"],
      "@nativescript/tanstack-router/solid": ["../../packages/tanstack-router/src/solid/index.ts"]
    },
    "noEmit": true,
    "allowJs": true,
    "types": ["node", "@nativescript-dom/core-types", "@nativescript-dom/solidjs-types"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmitHelpers": true,
    "importHelpers": true
  },
  "include": ["src", "references.d.ts"],
  "exclude": ["node_modules", "platforms", "**/*.test.ts", "**/*.spec.ts"]
}
